{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TensuGo",
  "version": "0.6.82",
  "identifier": "top.blackrice.tensugo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TensuGo",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/katago"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
