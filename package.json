{
  "name": "tensugo",
  "version": "0.6.18",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "version:bump": "node scripts/bump-version.mjs",
    "tauri:clean-cache": "node scripts/clean-tauri-cache.mjs",
    "package:win": "powershell -ExecutionPolicy Bypass -File scripts/package-windows.ps1",
    "package:mac": "npm run version:bump && npm run tauri:clean-cache && npm run tauri -- build && node scripts/label-mac-artifact.mjs",
    "install:mac": "bash scripts/install-mac-app.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
